# OPTIMIZED Environment Variables for Sarathi Agents
# Required for hackathon deployment with <2% error margin

# Google AI API (for gemini-1.5-flash-8b) - PRIMARY KEY
GOOGLE_API_KEY=your_google_api_key_here

# OpenWeather API (for weather tool)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Google Maps API (for mechanics/places)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Legacy keys (keep for compatibility)
GEMINI_API_KEY=your_google_api_key_here

# Database (optional for hackathon)
DATABASE_URL=postgresql://sarathi:sarathi123@db:5432/sarathi_db

# FastAPI Settings (optimized for speed)
ENVIRONMENT=production
LOG_LEVEL=WARNING
MAX_WORKERS=4

# Security (for JWT if needed)
SECRET_KEY=your-secret-key-change-this-in-production-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Redis (if used)
REDIS_URL=redis://redis:6379/0

# CORS Origins (comma-separated)
BACKEND_CORS_ORIGINS=["*"]

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
